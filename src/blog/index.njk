---
layout: "layouts/base.njk"
pagination:
  data: collections.posts
  size: 10
  alias: paginatedPosts
  reverse: false
permalink: "/blog/{% if pagination.pageNumber > 0 %}{{ pagination.pageNumber + 1 }}/{% endif %}"
eleventyComputed:
  title: "{% if pagination.pageNumber == 0 %}Blog | GA4 Optimizer{% else %}Blog - Page {{ pagination.pageNumber + 1 }} | GA4 Optimizer{% endif %}"
description: "Tips, tricks, and guides for making Google Analytics 4 easier to use and more powerful."
---
<main class="container">
    <div class="main-content content-page">
        <h1>GA4 Optimizer Blog</h1>
        <p>Actionable advice on solving common GA4 frustrations and getting more from your data.</p>
        
        <hr style="border-color: var(--border-color); margin-bottom: 40px;">

        <ul style="list-style: none; padding-left: 0;">
            {%- for post in paginatedPosts -%}
                <li class="blog-post-item">
                    <div class="blog-post-layout">
                        
                        <!-- Thumbnail Column -->
                        {%- if post.data.thumbnail -%}
                        <div class="blog-post-thumbnail-container">
                            <a href="{{ post.url }}">
                                <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}" class="blog-list-thumbnail">
                            </a>
                        </div>
                        {%- endif -%}

                        <!-- Text Content Column -->
                        <div class="blog-post-text-container">
                            <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
                            <p><em>Published on {{ (post.data.publishDate or post.date) | date("MMMM d, yyyy") }}</em></p>
                            <p>{{ post.data.description }}</p>
                            <p><a href="{{ post.url }}" style="font-weight: 600;">Read more...</a></p>
                        </div>

                    </div>
                </li>
            {%- endfor -%}
        </ul>

        <!-- Pagination Navigation -->
        {%- if pagination.pages.length > 1 -%}
        <nav class="blog-pagination" aria-label="Blog pagination">
            {%- if pagination.href.previous -%}
                <a href="{{ pagination.href.previous }}" class="pagination-link pagination-prev" rel="prev">&larr; Newer Posts</a>
            {%- else -%}
                <span class="pagination-link pagination-prev pagination-disabled" aria-disabled="true">&larr; Newer Posts</span>
            {%- endif -%}

            <span class="pagination-info">Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span>

            {%- if pagination.href.next -%}
                <a href="{{ pagination.href.next }}" class="pagination-link pagination-next" rel="next">More Posts &rarr;</a>
            {%- else -%}
                <span class="pagination-link pagination-next pagination-disabled" aria-disabled="true">More Posts &rarr;</span>
            {%- endif -%}
        </nav>
        {%- endif -%}

    </div>
</main>
